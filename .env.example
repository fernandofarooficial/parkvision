# Configurações do Banco de Dados
# Em desenvolvimento, usar SEMPRE um banco MySQL local — nunca apontar para a
# produção (VPS) para rodar a aplicação ou testes localmente.
DB_USER=pv_test
DB_PASSWORD=sua_senha_mysql_local
DB_HOST=localhost
DB_NAME=parkvision_test
DB_PORT=3306

# Configurações da Aplicação
FLASK_ENV=development
SECRET_KEY=gere-uma-chave-secreta-aleatoria-aqui

# Monitoramento de câmeras (intervalo em minutos)
CAM_MONITOR_INTERVAL_MIN=3

# Instruções:
# 1. Copie este arquivo para .env
# 2. Substitua a senha pela senha real do seu banco MySQL local
# 3. NUNCA aponte DB_HOST para a produção nem commite o arquivo .env para o repositório